<footer
  class="relative bg-white dark:bg-black border-t border-black dark:border-white px-6 md:px-12 lg:px-16 py-16 md:py-20"
>
  <div class="mx-auto w-full max-w-6xl">
    <!-- Logotype + tagline + invitation à contribuer -->
    <div class="mb-12 flex flex-col items-start gap-4 max-w-2xl">
      <a
        href="/"
        class="font-Scheherazade text-xl sm:text-2xl md:text-3xl uppercase tracking-[0.2em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        Conscience de classe
      </a>
      <p
        class="font-Scheherazade italic text-base sm:text-lg text-black dark:text-white"
      >
        Outil pour la révolution communiste. Corpus&nbsp;:
        <a
          href="/corpus"
          class="underline-offset-4 hover:underline hover:text-darkpink focus-visible:text-darkpink transition-colors"
          >archives du groupe Bilan (1933-1938)</a
        >.
      </p>
      <p
        class="font-Scheherazade text-sm sm:text-base text-black dark:text-white"
      >
        Ce travail est un projet ouvert. Toutes les critiques sont les
        bienvenues. N'hésitez pas à prendre contact —
        <a
          href="mailto:contact@consciencedeclasse.com"
          class="text-darkpink underline-offset-4 hover:underline focus-visible:underline transition-colors"
          >contact@consciencedeclasse.com</a
        >
      </p>
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-14 pt-6 border-t border-black dark:border-white flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 font-Scheherazade text-xs uppercase tracking-[0.2em] text-black dark:text-white"
    >
      <span>© 2026 — AGPL-3.0 · Corpus CC-BY-SA-4.0</span>
      <span>Aucune phrase non sourcée.</span>
    </div>

    <!-- Réseaux sociaux : tout en bas, ligne dédiée -->
    <nav
      aria-label="Réseaux sociaux"
      class="mt-10 flex flex-wrap items-center justify-center gap-x-8 sm:gap-x-12 gap-y-3 font-Scheherazade text-xs sm:text-sm uppercase tracking-[0.3em] text-black dark:text-white"
    >
      <a
        href="https://www.facebook.com/profile.php?id=61582449912701"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-darkpink focus-visible:text-darkpink underline-offset-4 hover:underline focus-visible:underline transition-colors"
      >
        Facebook
      </a>
      <a
        href="https://www.instagram.com/consciencedeclasse/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-darkpink focus-visible:text-darkpink underline-offset-4 hover:underline focus-visible:underline transition-colors"
      >
        Instagram
      </a>
      <a
        href="https://github.com/Consansclasse/class-consciousness"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-darkpink focus-visible:text-darkpink underline-offset-4 hover:underline focus-visible:underline transition-colors"
      >
        GitHub
      </a>
      <a
        href="https://tiktok.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-darkpink focus-visible:text-darkpink underline-offset-4 hover:underline focus-visible:underline transition-colors"
      >
        TikTok
      </a>
    </nav>
  </div>
</footer>
