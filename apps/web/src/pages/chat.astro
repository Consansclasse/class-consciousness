---
import ThemeToggle from "../components/ThemeToggle.astro";
// SPDX-License-Identifier: AGPL-3.0-or-later
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Conscience de classe — Conversation">
  <div class="flex h-dvh flex-col bg-white dark:bg-black">
    <!-- Header minimal, séparé du contenu par une fine ligne noire -->
    <header
      class="flex shrink-0 items-center justify-between px-6 lg:px-10 py-5 border-b border-black dark:border-white"
    >
      <a
        href="/"
        class="font-Scheherazade text-xs sm:text-sm uppercase tracking-[0.25em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        ← Retour
      </a>
      <a
        href="/"
        class="font-Scheherazade text-sm uppercase tracking-[0.2em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        Conscience de classe
      </a>
      <div class="flex items-center gap-6">
        <a
          href="/corpus"
          class="hidden sm:inline font-Scheherazade text-xs uppercase tracking-[0.25em] text-black dark:text-white hover:text-darkpink transition-colors"
        >
          Le corpus
        </a>
        <ThemeToggle />
      </div>
    </header>

    <!-- Zone scrollable : flex column qui occupe toute la hauteur disponible -->
    <main
      id="conv"
      class="flex-1 overflow-y-auto flex flex-col"
      aria-live="polite"
    >
      <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-6 md:px-10">
        <!-- Messages : séparés par fines lignes noires -->
        <ol
          id="messages"
          class="flex-1 divide-y divide-black dark:divide-white py-8"
        ></ol>
      </div>
    </main>

    <!-- Input : encadré d'une fine ligne noire, collé en bas avec un peu d'air -->
    <form
      id="chat-form"
      autocomplete="off"
      class="shrink-0 bg-white dark:bg-black px-6 md:px-10 pb-5 pt-2"
    >
      <div
        class="mx-auto flex w-full max-w-3xl items-end gap-3 border border-black dark:border-white px-4 py-3"
      >
        <textarea
          id="chat-input"
          name="q"
          rows="1"
          maxlength="500"
          aria-label="Votre question"
          class="min-h-[28px] max-h-48 flex-1 resize-none border-none bg-transparent py-1 font-Scheherazade text-lg leading-relaxed text-black dark:text-white outline-none"
        ></textarea>

        <button
          type="submit"
          id="chat-submit"
          aria-label="Envoyer"
          disabled
          class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-darkpink text-white transition-opacity hover:opacity-90 focus-visible:opacity-90 disabled:opacity-25 disabled:cursor-not-allowed"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
          >
            <path d="M12 19V5"></path>
            <path d="m5 12 7-7 7 7"></path>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const ta = document.getElementById("chat-input") as HTMLTextAreaElement;
    const btn = document.getElementById("chat-submit") as HTMLButtonElement;
    const list = document.getElementById("messages") as HTMLOListElement;
    const conv = document.getElementById("conv") as HTMLElement;

    // L'API min_length de la question est 3 caractères (cf. schemas/qa.py).
    const MIN_LEN = 3;
    const API_BASE = (
      import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8000"
    ).replace(/\/$/, "");

    type Citation = {
      sourceId: string;
      issueSlug: string;
      issueArk: string;
      articleSlug: string;
      articleArk: string;
      articleTitle: string;
      authorName: string;
      charStart: number;
      charEnd: number;
    };
    type Sentence = {
      text: string;
      citations: string[];
      verified: boolean;
      paragraphe: number;
    };
    type QaResponse = {
      answer: string | null;
      sentences: Sentence[];
      citedChunks: Citation[];
      incomplete: boolean;
      refusedReason: string | null;
    };

    const autosize = () => {
      ta.style.height = "auto";
      ta.style.height = Math.min(ta.scrollHeight, 192) + "px";
    };

    const escapeHtml = (s: string) =>
      s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const scrollDown = () => {
      requestAnimationFrame(() => {
        conv.scrollTo({ top: conv.scrollHeight, behavior: "smooth" });
      });
    };

    const noteHtml = (text: string) =>
      `<p class="font-Scheherazade italic text-sm sm:text-base leading-relaxed text-black dark:text-white">${escapeHtml(text)}</p>`;

    // `bilan-3` → `Bilan n°3` (libellé lisible du numéro).
    const issueLabel = (slug: string) => {
      const m = slug.match(/^bilan-0*(\d+)$/);
      return m ? `Bilan n°${m[1]}` : slug;
    };

    // Rend une réponse RAG structurée : chaque phrase vérifiée porte ses renvois
    // numérotés ⁽ⁿ⁾, les paragraphes d'origine sont préservés, et l'appareil de
    // sources complet (auteur, article, numéro, ARK, offsets) est listé dessous.
    const renderAnswer = (sentences: Sentence[], cited: Citation[]) => {
      const byId = new Map(cited.map((c) => [c.sourceId, c]));
      const verified = sentences.filter((s) => s.verified);
      const order: string[] = [];
      const numFor = (id: string) => {
        let i = order.indexOf(id);
        if (i === -1) {
          order.push(id);
          i = order.length - 1;
        }
        return i + 1;
      };
      // Regroupe les phrases par paragraphe d'origine.
      const paras = new Map<number, Sentence[]>();
      for (const s of verified) {
        const arr = paras.get(s.paragraphe) ?? [];
        arr.push(s);
        paras.set(s.paragraphe, arr);
      }
      let html = "";
      for (const [, group] of [...paras.entries()].sort((a, b) => a[0] - b[0])) {
        const inner = group
          .map((s) => {
            const sup = s.citations
              .filter((id) => id !== "none")
              .map(
                (id) => `<sup class="text-darkpink">(${numFor(id)})</sup>`,
              )
              .join("");
            return `${escapeHtml(s.text)}${sup}`;
          })
          .join(" ");
        html += `<p class="font-Scheherazade text-base sm:text-lg leading-relaxed text-black dark:text-white text-pretty mb-4">${inner}</p>`;
      }
      if (order.length > 0) {
        const items = order
          .map((id, idx) => {
            const c = byId.get(id);
            let inner: string;
            if (c) {
              const ref = `${escapeHtml(c.authorName)}, « ${escapeHtml(c.articleTitle)} », ${escapeHtml(issueLabel(c.issueSlug))}`;
              inner =
                `<a href="/corpus/${encodeURIComponent(c.issueSlug)}/${encodeURIComponent(c.articleSlug)}" ` +
                `class="hover:text-darkpink underline decoration-1 underline-offset-2">${ref}</a>` +
                ` <span class="opacity-60">— ${escapeHtml(c.articleArk)}, car. ${c.charStart}–${c.charEnd}</span>`;
            } else {
              inner = escapeHtml(id);
            }
            return `<li class="font-Scheherazade text-xs sm:text-sm text-black dark:text-white">(${idx + 1}) ${inner}</li>`;
          })
          .join("");
        html +=
          `<div class="mt-5 border-t border-black dark:border-white pt-3">` +
          `<p class="font-Scheherazade text-xs uppercase tracking-[0.2em] mb-2 opacity-70">Sources</p>` +
          `<ol class="space-y-1.5">${items}</ol></div>`;
      }
      return html;
    };

    const ask = async (q: string) => {
      const li = document.createElement("li");
      li.className = "space-y-4 py-8 first:pt-0 last:pb-0";
      li.innerHTML = `
        <p class="font-Scheherazade text-xl sm:text-2xl leading-snug text-black dark:text-white text-pretty">${escapeHtml(q)}</p>
        <div class="answer">${noteHtml("Recherche dans le corpus sourcé…")}</div>
      `;
      list.appendChild(li);
      scrollDown();
      const slot = li.querySelector(".answer") as HTMLElement;

      try {
        const res = await fetch(`${API_BASE}/qa`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ question: q }),
        });
        if (res.status === 503) {
          slot.innerHTML = noteHtml(
            "Le service est momentanément indisponible. Réessaie dans un instant.",
          );
        } else {
          const data = (await res.json()) as QaResponse;
          const sentences = data.sentences ?? [];
          const hasAnswer =
            !!data.answer && sentences.some((s) => s.verified);
          if (!hasAnswer) {
            slot.innerHTML = noteHtml(
              data.refusedReason === "no_relevant_chunks"
                ? "Le corpus disponible ne couvre pas cette question."
                : "Je ne peux pas répondre à partir des sources disponibles.",
            );
          } else {
            let html = renderAnswer(sentences, data.citedChunks ?? []);
            if (data.incomplete) {
              html += noteHtml(
                "Réponse partielle : les phrases non adossées à une citation vérifiée ont été retirées.",
              );
            }
            slot.innerHTML = html;
          }
        }
      } catch {
        slot.innerHTML = noteHtml(
          "La requête a échoué. Vérifie ta connexion et réessaie.",
        );
      }
      scrollDown();
    };

    ta.addEventListener("input", () => {
      autosize();
      btn.disabled = ta.value.trim().length < MIN_LEN;
    });

    ta.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const q = ta.value.trim();
      if (q.length < MIN_LEN) return;
      ta.value = "";
      autosize();
      btn.disabled = true;
      ta.focus();
      void ask(q);
    });

    // Préremplissage depuis ?q=…
    const params = new URLSearchParams(window.location.search);
    const initialQ = params.get("q")?.trim();
    if (initialQ && initialQ.length >= MIN_LEN) {
      ta.value = initialQ;
      autosize();
      btn.disabled = false;
      form.requestSubmit();
    } else {
      ta.focus();
    }
  </script>
</BaseLayout>
