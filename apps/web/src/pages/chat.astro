---
import ThemeToggle from "../components/ThemeToggle.astro";
// SPDX-License-Identifier: AGPL-3.0-or-later
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Conscience de classe — Conversation">
  <div class="flex h-dvh flex-col bg-white dark:bg-black">
    <!-- Header minimal, séparé du contenu par une fine ligne noire -->
    <header
      class="flex shrink-0 items-center justify-between px-6 lg:px-10 py-5 border-b border-black dark:border-white"
    >
      <a
        href="/"
        class="font-Scheherazade text-xs sm:text-sm uppercase tracking-[0.25em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        ← Retour
      </a>
      <a
        href="/"
        class="font-Scheherazade text-sm uppercase tracking-[0.2em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        Conscience de classe
      </a>
      <div class="flex items-center gap-6">
        <a
          href="/corpus"
          class="hidden sm:inline font-Scheherazade text-xs uppercase tracking-[0.25em] text-black dark:text-white hover:text-darkpink transition-colors"
        >
          Le corpus
        </a>
        <ThemeToggle />
      </div>
    </header>

    <!-- Zone scrollable : flex column qui occupe toute la hauteur disponible -->
    <main
      id="conv"
      class="flex-1 overflow-y-auto flex flex-col"
      aria-live="polite"
    >
      <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-6 md:px-10">
        <!-- Messages : séparés par fines lignes noires -->
        <ol
          id="messages"
          class="flex-1 divide-y divide-black dark:divide-white py-8"
        ></ol>
      </div>
    </main>

    <!-- Input : encadré d'une fine ligne noire, collé en bas avec un peu d'air -->
    <form
      id="chat-form"
      autocomplete="off"
      class="shrink-0 bg-white dark:bg-black px-6 md:px-10 pb-5 pt-2"
    >
      <div
        class="mx-auto flex w-full max-w-3xl items-end gap-3 border border-black dark:border-white px-4 py-3"
      >
        <textarea
          id="chat-input"
          name="q"
          rows="1"
          maxlength="500"
          aria-label="Votre question"
          class="min-h-[28px] max-h-48 flex-1 resize-none border-none bg-transparent py-1 font-Scheherazade text-lg leading-relaxed text-black dark:text-white outline-none"
        ></textarea>

        <button
          type="submit"
          id="chat-submit"
          aria-label="Envoyer"
          disabled
          class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-darkpink text-white transition-opacity hover:opacity-90 focus-visible:opacity-90 disabled:opacity-25 disabled:cursor-not-allowed"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
          >
            <path d="M12 19V5"></path>
            <path d="m5 12 7-7 7 7"></path>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const ta = document.getElementById("chat-input") as HTMLTextAreaElement;
    const btn = document.getElementById("chat-submit") as HTMLButtonElement;
    const list = document.getElementById("messages") as HTMLOListElement;
    const conv = document.getElementById("conv") as HTMLElement;

    // L'API min_length de la question est 3 caractères (cf. schemas/qa.py).
    const MIN_LEN = 3;
    const API_BASE = (
      import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8000"
    ).replace(/\/$/, "");

    type Citation = {
      sourceId: string;
      issueSlug: string;
      issueArk: string;
      articleSlug: string;
      articleArk: string;
      articleTitle: string;
      authorName: string;
      charStart: number;
      charEnd: number;
    };
    type Sentence = {
      text: string;
      citations: string[];
      verified: boolean;
      paragraphe: number;
    };
    type QaResponse = {
      answer: string | null;
      sentences: Sentence[];
      citedChunks: Citation[];
      incomplete: boolean;
      refusedReason: string | null;
    };

    const autosize = () => {
      ta.style.height = "auto";
      ta.style.height = Math.min(ta.scrollHeight, 192) + "px";
    };

    const escapeHtml = (s: string) =>
      s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const scrollDown = () => {
      requestAnimationFrame(() => {
        conv.scrollTo({ top: conv.scrollHeight, behavior: "smooth" });
      });
    };

    const noteHtml = (text: string) =>
      `<p class="font-Scheherazade italic text-sm sm:text-base leading-relaxed text-black dark:text-white">${escapeHtml(text)}</p>`;

    // Estimation de latence du pipeline RAG, mesurée bout-en-bout (~70 s :
    // génération ~52 s + vérification d'ancrage ~19 s). Sert de cible au
    // minuteur — informative, jamais bloquante.
    const ESTIMATE_S = 70;

    // `83` → `1:23` (minutes:secondes), format minuteur.
    const fmtClock = (s: number) =>
      `${Math.floor(s / 60)}:${(s % 60).toString().padStart(2, "0")}`;

    // Indicateur d'attente : libellé d'étape courante + barre de progression +
    // minuteur (temps écoulé / estimation). Le pipeline RAG prenant ~1 min, une
    // attente muette serait anxiogène — on rend la progression lisible. Renvoie
    // `setLabel` (maj du libellé d'étape) et `stop` (arrêt du minuteur).
    const startWaiter = (slot: HTMLElement) => {
      slot.innerHTML = `
        <div class="space-y-2.5">
          <p data-label class="font-Scheherazade italic text-sm sm:text-base leading-relaxed text-black dark:text-white">Analyse de la question…</p>
          <div
            data-bar
            role="progressbar"
            aria-label="Progression de la réponse"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            class="h-2 w-full border border-black dark:border-white"
          >
            <div
              data-fill
              class="h-full bg-darkpink transition-[width] duration-1000 ease-linear"
              style="width:0%"
            ></div>
          </div>
          <p
            data-time
            class="font-Scheherazade text-xs uppercase tracking-[0.15em] text-black dark:text-white opacity-70"
          >0:00 écoulé · estimation ≈ ${fmtClock(ESTIMATE_S)}</p>
        </div>`;
      const label = slot.querySelector("[data-label]") as HTMLElement;
      const bar = slot.querySelector("[data-bar]") as HTMLElement;
      const fill = slot.querySelector("[data-fill]") as HTMLElement;
      const time = slot.querySelector("[data-time]") as HTMLElement;
      const t0 = Date.now();
      const tick = () => {
        const el = Math.round((Date.now() - t0) / 1000);
        // La barre plafonne à 96 % : elle ne se « remplit » jamais tant que la
        // réponse vérifiée n'est pas arrivée — pas de faux signal d'achèvement.
        const pct = Math.min(96, (el / ESTIMATE_S) * 100);
        fill.style.width = pct + "%";
        bar.setAttribute("aria-valuenow", String(Math.round(pct)));
        time.textContent =
          el < ESTIMATE_S
            ? `${fmtClock(el)} écoulé · estimation ≈ ${fmtClock(ESTIMATE_S)}`
            : `${fmtClock(el)} écoulé · réponse imminente…`;
      };
      const id = window.setInterval(tick, 1000);
      return {
        setLabel: (txt: string) => {
          label.textContent = txt;
        },
        stop: () => window.clearInterval(id),
      };
    };

    // `bilan-3` → `Bilan n°3` (libellé lisible du numéro).
    const issueLabel = (slug: string) => {
      const m = slug.match(/^bilan-0*(\d+)$/);
      return m ? `Bilan n°${m[1]}` : slug;
    };

    // Rend une réponse RAG structurée : chaque phrase vérifiée porte ses renvois
    // numérotés ⁽ⁿ⁾, les paragraphes d'origine sont préservés, et l'appareil de
    // sources complet (auteur, article, numéro, ARK, offsets) est listé dessous.
    const renderAnswer = (sentences: Sentence[], cited: Citation[]) => {
      const byId = new Map(cited.map((c) => [c.sourceId, c]));
      const verified = sentences.filter((s) => s.verified);
      const order: string[] = [];
      const numFor = (id: string) => {
        let i = order.indexOf(id);
        if (i === -1) {
          order.push(id);
          i = order.length - 1;
        }
        return i + 1;
      };
      // Regroupe les phrases par paragraphe d'origine.
      const paras = new Map<number, Sentence[]>();
      for (const s of verified) {
        const arr = paras.get(s.paragraphe) ?? [];
        arr.push(s);
        paras.set(s.paragraphe, arr);
      }
      let html = "";
      for (const [, group] of [...paras.entries()].sort((a, b) => a[0] - b[0])) {
        const inner = group
          .map((s) => {
            const sup = s.citations
              .filter((id) => id !== "none")
              .map(
                (id) => `<sup class="text-darkpink">(${numFor(id)})</sup>`,
              )
              .join("");
            return `${escapeHtml(s.text)}${sup}`;
          })
          .join(" ");
        html += `<p class="font-Scheherazade text-base sm:text-lg leading-relaxed text-black dark:text-white text-pretty mb-4">${inner}</p>`;
      }
      if (order.length > 0) {
        const items = order
          .map((id, idx) => {
            const c = byId.get(id);
            let inner: string;
            if (c) {
              const ref = `${escapeHtml(c.authorName)}, « ${escapeHtml(c.articleTitle)} », ${escapeHtml(issueLabel(c.issueSlug))}`;
              inner =
                `<a href="/corpus/${encodeURIComponent(c.issueSlug)}/${encodeURIComponent(c.articleSlug)}" ` +
                `class="hover:text-darkpink underline decoration-1 underline-offset-2">${ref}</a>` +
                ` <span class="opacity-60">— ${escapeHtml(c.articleArk)}, car. ${c.charStart}–${c.charEnd}</span>`;
            } else {
              inner = escapeHtml(id);
            }
            return `<li class="font-Scheherazade text-xs sm:text-sm text-black dark:text-white">(${idx + 1}) ${inner}</li>`;
          })
          .join("");
        html +=
          `<div class="mt-5 border-t border-black dark:border-white pt-3">` +
          `<p class="font-Scheherazade text-xs uppercase tracking-[0.2em] mb-2 opacity-70">Sources</p>` +
          `<ol class="space-y-1.5">${items}</ol></div>`;
      }
      return html;
    };

    // Affiche la réponse finale (vérifiée) ou le message de refus adéquat.
    const renderResult = (data: QaResponse, slot: HTMLElement) => {
      const sentences = data.sentences ?? [];
      const hasAnswer = !!data.answer && sentences.some((s) => s.verified);
      if (!hasAnswer) {
        slot.innerHTML = noteHtml(
          data.refusedReason === "no_relevant_chunks"
            ? "Le corpus disponible ne couvre pas cette question."
            : "Je ne peux pas répondre à partir des sources disponibles.",
        );
        return;
      }
      let html = renderAnswer(sentences, data.citedChunks ?? []);
      if (data.incomplete) {
        html += noteHtml(
          "Réponse partielle : les phrases non adossées à une citation vérifiée ont été retirées.",
        );
      }
      slot.innerHTML = html;
    };

    const ask = async (q: string) => {
      const li = document.createElement("li");
      li.className = "space-y-4 py-8 first:pt-0 last:pb-0";
      li.innerHTML = `
        <p class="font-Scheherazade text-xl sm:text-2xl leading-snug text-black dark:text-white text-pretty">${escapeHtml(q)}</p>
        <div class="answer"></div>
      `;
      list.appendChild(li);
      scrollDown();
      const slot = li.querySelector(".answer") as HTMLElement;

      // Minuteur d'attente : démarre immédiatement, avant même la connexion SSE.
      const waiter = startWaiter(slot);

      // Le pipeline RAG prend des dizaines de secondes (3 appels LLM). On
      // consomme le flux Server-Sent Events de `/qa/stream` : les évènements
      // `stage` affichent la progression, `result` porte la réponse vérifiée.
      try {
        const res = await fetch(`${API_BASE}/qa/stream`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ question: q }),
        });
        if (!res.ok || !res.body) {
          waiter.stop();
          slot.innerHTML = noteHtml(
            "Le service est momentanément indisponible. Réessaie dans un instant.",
          );
          scrollDown();
          return;
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = "";
        let finished = false;
        while (!finished) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const blocks = buf.split("\n\n");
          buf = blocks.pop() ?? "";
          for (const block of blocks) {
            const trimmed = block.trim();
            if (!trimmed || trimmed.startsWith(":")) continue; // ping / commentaire
            let event = "message";
            let data = "";
            for (const line of block.split("\n")) {
              if (line.startsWith("event:")) event = line.slice(6).trim();
              else if (line.startsWith("data:")) data += line.slice(5).trim();
            }
            if (event === "stage") {
              waiter.setLabel((JSON.parse(data) as { label: string }).label);
              scrollDown();
            } else if (event === "result") {
              waiter.stop();
              renderResult(JSON.parse(data) as QaResponse, slot);
              finished = true;
            } else if (event === "error") {
              waiter.stop();
              slot.innerHTML = noteHtml(
                (JSON.parse(data) as { detail: string }).detail,
              );
              finished = true;
            }
          }
        }
        // Filet de sécurité : flux clos sans évènement `result` (cf. `break`
        // sur `done`) — on arrête le minuteur dans tous les cas.
        waiter.stop();
      } catch {
        waiter.stop();
        slot.innerHTML = noteHtml(
          "La requête a échoué. Vérifie ta connexion et réessaie.",
        );
      }
      scrollDown();
    };

    ta.addEventListener("input", () => {
      autosize();
      btn.disabled = ta.value.trim().length < MIN_LEN;
    });

    ta.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const q = ta.value.trim();
      if (q.length < MIN_LEN) return;
      ta.value = "";
      autosize();
      btn.disabled = true;
      ta.focus();
      void ask(q);
    });

    // Préremplissage depuis ?q=…
    const params = new URLSearchParams(window.location.search);
    const initialQ = params.get("q")?.trim();
    if (initialQ && initialQ.length >= MIN_LEN) {
      ta.value = initialQ;
      autosize();
      btn.disabled = false;
      form.requestSubmit();
    } else {
      ta.focus();
    }
  </script>
</BaseLayout>
