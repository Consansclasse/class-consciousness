---
import ThemeToggle from "../components/ThemeToggle.astro";
// SPDX-License-Identifier: AGPL-3.0-or-later
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Conscience de classe — Conversation">
  <div class="flex h-dvh flex-col bg-white dark:bg-black">
    <!-- Header minimal, séparé du contenu par une fine ligne noire -->
    <header
      class="flex shrink-0 items-center justify-between px-6 lg:px-10 py-5 border-b border-black dark:border-white"
    >
      <a
        href="/"
        class="font-Scheherazade text-xs sm:text-sm uppercase tracking-[0.25em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        ← Retour
      </a>
      <a
        href="/"
        class="font-Scheherazade text-sm uppercase tracking-[0.2em] text-black dark:text-white hover:text-darkpink transition-colors"
      >
        Conscience de classe
      </a>
      <div class="flex items-center gap-6">
        <a
          href="/corpus"
          class="hidden sm:inline font-Scheherazade text-xs uppercase tracking-[0.25em] text-black dark:text-white hover:text-darkpink transition-colors"
        >
          Le corpus
        </a>
        <ThemeToggle />
      </div>
    </header>

    <!-- Zone scrollable : flex column qui occupe toute la hauteur disponible -->
    <main
      id="conv"
      class="flex-1 overflow-y-auto flex flex-col"
      aria-live="polite"
    >
      <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-6 md:px-10">
        <!-- Messages : séparés par fines lignes noires -->
        <ol
          id="messages"
          class="flex-1 divide-y divide-black dark:divide-white py-8"
        ></ol>
      </div>
    </main>

    <!-- Input : encadré d'une fine ligne noire, collé en bas avec un peu d'air -->
    <form
      id="chat-form"
      autocomplete="off"
      class="shrink-0 bg-white dark:bg-black px-6 md:px-10 pb-5 pt-2"
    >
      <div
        class="mx-auto flex w-full max-w-3xl items-end gap-3 border border-black dark:border-white px-4 py-3"
      >
        <textarea
          id="chat-input"
          name="q"
          rows="1"
          maxlength="500"
          aria-label="Votre question"
          class="min-h-[28px] max-h-48 flex-1 resize-none border-none bg-transparent py-1 font-Scheherazade text-lg leading-relaxed text-black dark:text-white outline-none"
        ></textarea>

        <button
          type="submit"
          id="chat-submit"
          aria-label="Envoyer"
          disabled
          class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-darkpink text-white transition-opacity hover:opacity-90 focus-visible:opacity-90 disabled:opacity-25 disabled:cursor-not-allowed"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4"
          >
            <path d="M12 19V5"></path>
            <path d="m5 12 7-7 7 7"></path>
          </svg>
        </button>
      </div>
    </form>
  </div>

  <script>
    const form = document.getElementById("chat-form") as HTMLFormElement;
    const ta = document.getElementById("chat-input") as HTMLTextAreaElement;
    const btn = document.getElementById("chat-submit") as HTMLButtonElement;
    const list = document.getElementById("messages") as HTMLOListElement;
    const conv = document.getElementById("conv") as HTMLElement;

    // L'API min_length de la question est 3 caractères (cf. schemas/qa.py).
    const MIN_LEN = 3;
    const API_BASE = (
      import.meta.env.PUBLIC_API_BASE_URL ?? "http://localhost:8000"
    ).replace(/\/$/, "");

    type Citation = {
      sourceId: string;
      issueSlug: string;
      articleSlug: string;
      articleTitle: string;
      authorName: string;
    };
    type QaResponse = {
      answer: string | null;
      citedChunks: Citation[];
      incomplete: boolean;
    };

    const autosize = () => {
      ta.style.height = "auto";
      ta.style.height = Math.min(ta.scrollHeight, 192) + "px";
    };

    const escapeHtml = (s: string) =>
      s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const scrollDown = () => {
      requestAnimationFrame(() => {
        conv.scrollTo({ top: conv.scrollHeight, behavior: "smooth" });
      });
    };

    const noteHtml = (text: string) =>
      `<p class="font-Scheherazade italic text-sm sm:text-base leading-relaxed text-black dark:text-white">${escapeHtml(text)}</p>`;

    // Rend une réponse RAG : remplace les marqueurs [CITE:source_id] par des
    // renvois numérotés et liste les sources dessous (liens vers /corpus).
    const renderAnswer = (answer: string, cited: Citation[]) => {
      const byId = new Map(cited.map((c) => [c.sourceId, c]));
      const order: string[] = [];
      const numFor = (id: string) => {
        let i = order.indexOf(id);
        if (i === -1) {
          order.push(id);
          i = order.length - 1;
        }
        return i + 1;
      };
      const withRefs = escapeHtml(answer).replace(
        /\[CITE:([^\]]+)\]/g,
        (_m, id: string) =>
          id === "none"
            ? ""
            : `<sup class="text-darkpink">[${numFor(id)}]</sup>`,
      );
      let html = `<p class="font-Scheherazade text-base sm:text-lg leading-relaxed text-black dark:text-white text-pretty">${withRefs}</p>`;
      if (order.length > 0) {
        const items = order
          .map((id, idx) => {
            const c = byId.get(id);
            const label = c
              ? `${escapeHtml(c.articleTitle)} — ${escapeHtml(c.authorName)}`
              : escapeHtml(id);
            const inner = c
              ? `<a href="/corpus/${encodeURIComponent(c.issueSlug)}/${encodeURIComponent(c.articleSlug)}" class="hover:text-darkpink underline decoration-1 underline-offset-2">${label}</a>`
              : label;
            return `<li class="font-Scheherazade text-xs sm:text-sm text-black dark:text-white">[${idx + 1}] ${inner}</li>`;
          })
          .join("");
        html += `<ol class="mt-3 space-y-1 border-t border-black dark:border-white pt-3">${items}</ol>`;
      }
      return html;
    };

    const ask = async (q: string) => {
      const li = document.createElement("li");
      li.className = "space-y-4 py-8 first:pt-0 last:pb-0";
      li.innerHTML = `
        <p class="font-Scheherazade text-xl sm:text-2xl leading-snug text-black dark:text-white text-pretty">${escapeHtml(q)}</p>
        <div class="answer">${noteHtml("Recherche dans le corpus sourcé…")}</div>
      `;
      list.appendChild(li);
      scrollDown();
      const slot = li.querySelector(".answer") as HTMLElement;

      try {
        const res = await fetch(`${API_BASE}/qa`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ question: q }),
        });
        if (res.status === 503) {
          slot.innerHTML = noteHtml(
            "Le service est momentanément indisponible. Réessaie dans un instant.",
          );
        } else {
          const data = (await res.json()) as QaResponse;
          if (!data.answer) {
            slot.innerHTML = noteHtml(
              "Je ne peux pas répondre à partir des sources disponibles.",
            );
          } else {
            let html = renderAnswer(data.answer, data.citedChunks ?? []);
            if (data.incomplete) {
              html += noteHtml(
                "Réponse partielle : les phrases non adossées à une citation vérifiée ont été retirées.",
              );
            }
            slot.innerHTML = html;
          }
        }
      } catch {
        slot.innerHTML = noteHtml(
          "La requête a échoué. Vérifie ta connexion et réessaie.",
        );
      }
      scrollDown();
    };

    ta.addEventListener("input", () => {
      autosize();
      btn.disabled = ta.value.trim().length < MIN_LEN;
    });

    ta.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const q = ta.value.trim();
      if (q.length < MIN_LEN) return;
      ta.value = "";
      autosize();
      btn.disabled = true;
      ta.focus();
      void ask(q);
    });

    // Préremplissage depuis ?q=…
    const params = new URLSearchParams(window.location.search);
    const initialQ = params.get("q")?.trim();
    if (initialQ && initialQ.length >= MIN_LEN) {
      ta.value = initialQ;
      autosize();
      btn.disabled = false;
      form.requestSubmit();
    } else {
      ta.focus();
    }
  </script>
</BaseLayout>
