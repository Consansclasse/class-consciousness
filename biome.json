{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": { "ignoreUnknown": true, "ignore": ["**/dist", "**/.astro", "**/node_modules"] },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 120 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": { "noBannedTypes": "error" },
      "suspicious": { "noExplicitAny": "error" },
      "style": { "useImportType": "warn" }
    }
  },
  "overrides": [
    {
      "include": ["apps/web/tests/e2e/fixtures/**"],
      "linter": {
        "rules": {
          "suspicious": { "noConfusingVoidType": "off" },
          "correctness": { "noEmptyPattern": "off" }
        }
      }
    }
  ],
  "javascript": { "formatter": { "quoteStyle": "double", "semicolons": "always" } }
}
