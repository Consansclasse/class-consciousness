# Backend
CC_API_HOST=0.0.0.0
CC_API_PORT=8000
CC_API_LOG_LEVEL=INFO
CC_API_ENV=dev

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=class_consciousness
POSTGRES_USER=cc
POSTGRES_PASSWORD=changeme

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# Redis
REDIS_URL=redis://redis:6379/0

# LLM (Anthropic Claude Opus 4.7)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MODEL_PREPROCESS=claude-haiku-4-5

# Embeddings + reranking — serveur cc-embed (Qwen3 0.6B sur CPU, apps/embed-server).
# En prod, cc-embed est un service du compose, joint via http://cc-embed:8001.
CC_API_EMBED_SERVER_URL=http://127.0.0.1:8001
CC_API_EMBED_DIM=1024
CC_API_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# Stripe — paiement de la cotisation associative (clés sk_test_… en dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Web
PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_WEB_BASE=http://localhost:3000
SITE_URL=http://localhost:3000

# ARK
ARK_NAAN=99999
ARK_RESOLVER=https://n2t.net

# Corpus — dépôt séparé class-consciousness-corpus
# Optionnel : chemin absolu vers le clone du dépôt corpus.
# Défaut si non défini : dossier voisin « ../class-consciousness-corpus ».
# CC_CORPUS_DIR=/chemin/absolu/vers/class-consciousness-corpus
