# syntax=docker/dockerfile:1.7
# Image du serveur cc-embed (Qwen3-Embedding-0.6B + Qwen3-Reranker-0.6B, CPU).
# torch est résolu depuis l'index CPU (cf. pyproject.toml racine) — pas de CUDA.

FROM python:3.12-slim AS base
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1
WORKDIR /app
COPY --from=ghcr.io/astral-sh/uv:0.4.18 /uv /usr/local/bin/uv

FROM base AS deps
COPY pyproject.toml uv.lock* /app/
COPY apps/api/pyproject.toml /app/apps/api/
COPY packages/corpus-tools/pyproject.toml /app/packages/corpus-tools/
COPY apps/embed-server/pyproject.toml /app/apps/embed-server/
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --package cc-embed

FROM deps AS prod
COPY apps/embed-server /app/apps/embed-server
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --package cc-embed \
    && mkdir -p /app/hf-cache \
    && chown -R 1000:1000 /app/.venv /app/hf-cache
# HF_HOME pointe sur un volume monté : les poids des modèles ne sont téléchargés
# qu'une fois. CC_EMBED_HOST=0.0.0.0 : joignable par l'API sur le réseau Docker.
ENV PATH="/app/.venv/bin:$PATH" \
    HF_HOME=/app/hf-cache \
    CC_EMBED_HOST=0.0.0.0
EXPOSE 8001
USER 1000:1000
CMD ["python", "-m", "cc_embed"]
